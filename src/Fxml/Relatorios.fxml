<AnchorPane id="AnchorPane" fx:id="anRelatorios" prefHeight="600.0" prefWidth="891.0" style="-fx-background-color: #032221;" styleClass="mainFxmlClass" stylesheets="@../Css/relatorios.css" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.RelatoriosController">
   <children>
      <Button fx:id="btnVoltar" accessibleRole="IMAGE_VIEW" alignment="CENTER" contentDisplay="CENTER" layoutX="23.0" layoutY="18.0" mnemonicParsing="false" onAction="#btnVoltarAction" prefHeight="52.0" prefWidth="57.0" stylesheets="@../Css/relatorios.css">
         <graphic>
            <ImageView fx:id="imgX" fitHeight="30.0" fitWidth="21.0" pickOnBounds="true" preserveRatio="true" style="-fx-effect: dropshadow(three-pass-box, rgb(44,194,149,0.8), 10, 0, 0, 0);;">
               <image>
                  <Image url="@../imagens/voltar.png" />
               </image>
            </ImageView>
         </graphic>
      </Button>
      <Label fx:id="lblTitulo" alignment="CENTER" layoutX="60.0" layoutY="14.0" prefHeight="59.0" prefWidth="770.0" stylesheets="@../Css/StylePrincipal.css" text="Relatórios" />
      <HBox fx:id="hBoxPrincipalRelatorios" alignment="CENTER" layoutY="71.0" prefHeight="406.0" prefWidth="891.0">
         <children>
            <ListView fx:id="lstRelatorios" prefHeight="348.0" prefWidth="406.0" stylesheets="@../Css/relatorios.css">
               <HBox.margin>
                  <Insets left="10.0" right="10.0" top="15.0" />
               </HBox.margin>
            </ListView>
            <TextArea fx:id="txtRelatorio" prefHeight="348.0" prefWidth="418.0" stylesheets="@../Css/relatorios.css">
               <HBox.margin>
                  <Insets left="10.0" right="10.0" top="15.0" />
               </HBox.margin>
            </TextArea>
         </children>
      </HBox>
      <HBox fx:id="hBoxBotoesRelatorio" alignment="CENTER" layoutX="6.0" layoutY="486.0" prefHeight="100.0" prefWidth="885.0">
         <children>
            <Button fx:id="btnVisualizar" mnemonicParsing="false" onAction="#btnVisualizarction" prefHeight="35.0" prefWidth="148.0" stylesheets="@../Css/relatorios.css" text="Visualizar">
               <HBox.margin>
                  <Insets left="5.0" right="5.0" />
               </HBox.margin>
            </Button>
            <Button fx:id="btnExcluir" layoutX="379.0" layoutY="42.0" mnemonicParsing="false" onAction="#btnExcluirAction" prefHeight="35.0" prefWidth="148.0" stylesheets="@../Css/relatorios.css" text="Excluir">
               <HBox.margin>
                  <Insets left="5.0" right="5.0" />
               </HBox.margin>
            </Button>
            <Button fx:id="btnAtualizar" layoutX="453.0" layoutY="42.0" mnemonicParsing="false" onAction="#btnAtualizarAction" prefHeight="35.0" prefWidth="148.0" stylesheets="@../Css/relatorios.css" text="Atualizar">
               <HBox.margin>
                  <Insets left="5.0" right="5.0" />
               </HBox.margin>
            </Button>
         </children>
      </HBox>
   </children>
